rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Common auth check
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the requesting user is an Admin
    function isAdmin() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Checks if the user's role is 'Service Provider'.
    function isServiceProvider() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Service Provider';
    }

    function isShopManager() {
      return isSignedIn() &&
             (
               request.auth.token.email == 'shop@gmail.com' ||
               (
                 exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                 (
                   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'shop' ||
                   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Shop Manager'
                 )
               )
             );
    }

    // ---- Lightweight validators (non-breaking) ----
    function isOptionalString(v) { return v == null || v is string; }
    function isNonEmptyString(v) { return v is string && v.size() > 0; }
    function isOptionalGeo(v) { return v == null || v is latlng; }
    function isOptionalBool(v) { return v == null || v is bool; }
    function isOptionalNumber(v) { return v == null || v is number; }
    function isOptionalAttachments(arr) { return arr == null || (arr is list && arr.size() <= 20); }
    function isPhoneValid(p) { return p == null || (p is string && p.matches('^\\d{10,15}$')); }
    function isOptionalPincodeValid(p) { return p == null || (p is string && (p.size() == 0 || p.matches('^\\d{6}$'))); }
    function isOptionalStringList(arr, max) { return arr == null || (arr is list && arr.size() <= max); }
    function isEmailValid(e) { return e == null || (e is string && e.matches('^.+@.+\\..+$')); }
    function isOptionalTimestamp(t) { return t == null || t is timestamp; }
    function isOptionalStringMax(v, max) { return v == null || (v is string && v.size() <= max); }
    function isDeliveredValue(v) { return v is string && v.matches('(?i)^\\s*delivered\\s*$'); }
    function isRejectedValue(v) { return v is string && v.matches('(?i)^\\s*rejected\\s*$'); }
    function isRequestedValue(v) { return v is string && v.matches('(?i)^\\s*requested\\s*$'); }
    function isReturnOrReplacementType(v) { return v is string && v.matches('(?i)^\\s*(return|replacement)\\s*$'); }

    function isChatParticipant(chat) {
      return isSignedIn() &&
             chat != null &&
             (chat.customerId == request.auth.uid || chat.providerId == request.auth.uid);
    }

    function isRequestParticipant(requestId) {
      let req = get(/databases/$(database)/documents/serviceRequests/$(requestId)).data;
      return isSignedIn() &&
             req != null &&
             (req.customerId == request.auth.uid || req.providerId == request.auth.uid || isAdmin());
    }

    // More flexible validation for service request creation
    function serviceRequestCreateValid() {
      let d = request.resource.data;

      let requiredOk = isNonEmptyString(d.serviceId) &&
                       isNonEmptyString(d.providerId) &&
                       isNonEmptyString(d.serviceName) &&
                       isNonEmptyString(d.customerId) &&
                       d.scheduledDateTime is timestamp;

      let addressOk = d.addressSnapshot == null || d.addressSnapshot is map;
      let contactOk = d.contact == null || (d.contact is map && isPhoneValid(d.contact.phone));
      let onTimeOk = isOptionalBool(d.onTime);
      let estimatedDaysOk = d.estimatedDurationDays == null || (isOptionalNumber(d.estimatedDurationDays) && d.estimatedDurationDays >= 0 && d.estimatedDurationDays <= 365);
      let attachmentsOk = isOptionalAttachments(d.attachments);

      return requiredOk && addressOk && contactOk && onTimeOk && estimatedDaysOk && attachmentsOk;
    }

    // ---------------- Service creation/update validation ----------------
    function serviceCreateValid() {
      let d = request.resource.data;

      let requiredOk =
        isNonEmptyString(d.providerId) &&
        isNonEmptyString(d.serviceName) &&
        isNonEmptyString(d.description) &&
        isNonEmptyString(d.serviceImageUrl);

      let categoryOk =
        isOptionalString(d.category) &&
        isOptionalString(d.categoryId) &&
        isOptionalString(d.categoryName);

      let subcatsOk =
        isOptionalString(d.subCategoryId) &&
        isOptionalString(d.subCategoryName) &&
        isOptionalStringList(d.subCategoryIds, 20) &&
        isOptionalStringList(d.subCategoryNames, 50);

      let optionalInfoOk =
        isOptionalString(d.terms) &&
        isPhoneValid(d.contactPhone) &&
        isEmailValid(d.contactEmail) &&
        isOptionalString(d.websiteUrl) &&
        isOptionalBool(d.isAvailable);

      let locationOk =
        isOptionalString(d.locationAddress) &&
        isOptionalString(d.addressDisplay) &&
        isOptionalGeo(d.locationGeoPoint) &&
        isOptionalNumber(d.lat) &&
        isOptionalNumber(d.lng) &&
        isOptionalString(d.geohash) &&
        isOptionalStringList(d.serviceAreas, 50);

      let timestampsOk = d.createdAt == null || d.createdAt is timestamp;

      return requiredOk && categoryOk && subcatsOk && optionalInfoOk && locationOk && timestampsOk;
    }

    function serviceUpdateValid() {
      let d = request.resource.data;
      let old = resource.data;
      let providerSame = d.providerId == old.providerId;
      return providerSame && serviceCreateValid();
    }

    // ---------------- Review validation (SIMPLIFIED & FIXED) ----------------
    function serviceReviewBasicValid() {
      let d = request.resource.data;

      let requiredOk =
        isNonEmptyString(d.requestId) &&
        isNonEmptyString(d.customerId) &&
        isOptionalString(d.serviceName);

      // providerId may be unavailable in some legacy notification paths.
      let providerOk = isOptionalString(d.providerId);

      let ratingOk = d.rating is number && d.rating >= 1 && d.rating <= 5;
      let commentOk = isOptionalStringMax(d.comment, 2000);
      let optionalOk =
        isOptionalString(d.serviceId) &&
        isOptionalStringMax(d.customerName, 120) &&
        isOptionalTimestamp(d.createdAt) &&
        isOptionalTimestamp(d.updatedAt);

      return requiredOk && providerOk && ratingOk && commentOk && optionalOk;
    }

    // ---------------- Shop order validation ----------------
    function shopOrderDataValid(d) {
      let ownerOk =
        isNonEmptyString(d.customerId) &&
        d.customerId == request.auth.uid &&
        (d.userId == null || d.userId == request.auth.uid);

      let requiredOk =
        isNonEmptyString(d.itemId) &&
        isNonEmptyString(d.itemName) &&
        (isNonEmptyString(d.categoryName) || isNonEmptyString(d.category));

      let amountOk =
        d.quantity is number && d.quantity > 0 &&
        d.unitPrice is number && d.unitPrice >= 0 &&
        d.totalAmount is number && d.totalAmount >= 0;

      let optionalOk =
        isOptionalString(d.paymentId) &&
        isOptionalString(d.paymentMethod) &&
        isOptionalString(d.orderStatus) &&
        isOptionalString(d.currency) &&
        isOptionalString(d.customerEmail) &&
        isOptionalString(d.itemImageUrl) &&
        isOptionalTimestamp(d.createdAt) &&
        isOptionalNumber(d.createdAtLocalMs);

      return ownerOk && requiredOk && amountOk && optionalOk;
    }

    // ---------------- Shop product review validation ----------------
    function shopItemReviewValid(d) {
      let requiredOk =
        isNonEmptyString(d.orderId) &&
        isNonEmptyString(d.itemId) &&
        isNonEmptyString(d.customerId);

      let ratingOk = d.rating is number && d.rating >= 1 && d.rating <= 5;
      let commentOk = isOptionalStringMax(d.comment, 2000);
      let optionalOk =
        isOptionalStringMax(d.itemName, 180) &&
        isOptionalStringMax(d.customerName, 120) &&
        isOptionalTimestamp(d.createdAt) &&
        isOptionalTimestamp(d.updatedAt);

      return requiredOk && ratingOk && commentOk && optionalOk;
    }

    function isDeliveredShopOrderDoc(path, itemId) {
      return exists(path) &&
             get(path).data.customerId == request.auth.uid &&
             get(path).data.itemId == itemId &&
             (
               isDeliveredValue(get(path).data.deliveryStatus) ||
               isDeliveredValue(get(path).data.orderStatus)
             );
    }

    function hasDeliveredShopOrder(orderId, itemId) {
      let globalOrderPath = /databases/$(database)/documents/shopOrders/$(orderId);
      let userOrderPath = /databases/$(database)/documents/users/$(request.auth.uid)/shopOrders/$(orderId);
      return isDeliveredShopOrderDoc(globalOrderPath, itemId) ||
             isDeliveredShopOrderDoc(userOrderPath, itemId);
    }

    function shopReturnReplacementRequestValid(rr) {
      return rr is map &&
             rr.keys().hasOnly([
               'requestType',
               'status',
               'reason',
               'itemName',
               'requestedBy',
               'requestedAt',
               'requestedAtLocalMs',
               'updatedAt',
               'updatedAtLocalMs'
             ]) &&
             isReturnOrReplacementType(rr.requestType) &&
             isRequestedValue(rr.status) &&
             isNonEmptyString(rr.reason) &&
             isOptionalStringMax(rr.reason, 2000) &&
             isOptionalStringMax(rr.itemName, 200) &&
             rr.requestedBy == request.auth.uid &&
             isOptionalTimestamp(rr.requestedAt) &&
             (rr.requestedAtLocalMs == null || (rr.requestedAtLocalMs is number && rr.requestedAtLocalMs > 0)) &&
             isOptionalTimestamp(rr.updatedAt) &&
             (rr.updatedAtLocalMs == null || (rr.updatedAtLocalMs is number && rr.updatedAtLocalMs > 0));
    }

    function customerGlobalShopOrderReturnReplacementUpdateValid(orderId) {
      let d = request.resource.data;
      let old = resource.data;
      let rr = d.returnReplacementRequest;
      let oldRr = old.returnReplacementRequest;
      let userOrderPath = /databases/$(database)/documents/users/$(request.auth.uid)/shopOrders/$(orderId);

      let changedOnlyReturnRequest =
        d.diff(old).changedKeys().hasOnly(['returnReplacementRequest']);

      let ownerOk =
        old.customerId == request.auth.uid ||
        old.userId == request.auth.uid ||
        d.customerId == request.auth.uid ||
        d.userId == request.auth.uid ||
        exists(userOrderPath);

      let deliveredOk =
        (
          isDeliveredValue(old.deliveryStatus)
        ) ||
        (
          isDeliveredValue(old.orderStatus)
        ) ||
        (
          exists(userOrderPath) &&
          (
            isDeliveredValue(get(userOrderPath).data.deliveryStatus) ||
            isDeliveredValue(get(userOrderPath).data.orderStatus)
          )
        );

      let oldRequestOk =
        oldRr == null ||
        oldRr.status == null ||
        oldRr.status == '' ||
        isRejectedValue(oldRr.status);

      return isSignedIn() &&
             changedOnlyReturnRequest &&
             ownerOk &&
             deliveredOk &&
             oldRequestOk &&
             shopReturnReplacementRequestValid(rr);
    }

    // ---------------- categories ----------------
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && isAdmin();
    }

    // ---------------- subcategories ----------------
    match /subcategories/{subCategoryId} {
      allow read: if true;
      allow create: if request.auth != null && (isServiceProvider() || isAdmin());
      allow update, delete: if request.auth != null && isAdmin();
    }

    // ---------------- users ----------------
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());

      match /availability/{docId} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }

      match /fcmTokens/{tokenId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }

      // Customer-scoped shop orders (fallback path used by app)
      match /shopOrders/{orderId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
        allow create: if isSignedIn() &&
                      request.auth.uid == userId &&
                      shopOrderDataValid(request.resource.data);
        allow update: if isSignedIn() &&
                      (request.auth.uid == userId || isAdmin() || isShopManager());
        allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    // ---------------- shop login collection ----------------
    match /shop/{shopId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    // ---------------- shopOrders (global) ----------------
    match /shopOrders/{orderId} {
      allow read: if isSignedIn() &&
                  (resource.data.customerId == request.auth.uid ||
                   resource.data.userId == request.auth.uid ||
                   isAdmin() ||
                   isShopManager());

      allow create: if isSignedIn() &&
                    shopOrderDataValid(request.resource.data);

      // Managers/admins keep full control; customer gets limited return/replacement request update.
      allow update: if isSignedIn() &&
                    (
                      isAdmin() ||
                      isShopManager() ||
                      customerGlobalShopOrderReturnReplacementUpdateValid(orderId)
                    );
      allow delete: if isSignedIn() && isAdmin();
    }

    // ---------------- services ----------------
    match /services/{serviceId} {
      allow read: if true;

      allow create: if request.auth != null &&
                       isServiceProvider() &&
                       request.auth.uid == request.resource.data.providerId &&
                       serviceCreateValid();

      allow update: if request.auth != null &&
                       request.auth.uid == resource.data.providerId &&
                       serviceUpdateValid();

      allow delete: if request.auth != null &&
                       (request.auth.uid == resource.data.providerId || isAdmin());
    }

    // ---------------- providers ----------------
    match /providers/{providerId} {
      // Needed by chatbot for _fetchProvidersByAppliance
      allow read: if true;

      // Allow providers to create/update their own profile docs
      allow create: if request.auth != null &&
                      isServiceProvider() &&
                      request.auth.uid == providerId;
      allow update: if request.auth != null &&
                      isServiceProvider() &&
                      request.auth.uid == providerId;
      allow delete: if request.auth != null &&
                      (request.auth.uid == providerId || isAdmin());
    }

    // ---------------- serviceRequests (bookings) ----------------
    match /serviceRequests/{requestId} {
      allow create: if request.auth != null &&
                       request.resource.data.customerId == request.auth.uid &&
                       serviceRequestCreateValid();

      allow read: if request.auth != null &&
                     (resource.data.customerId == request.auth.uid ||
                      resource.data.providerId == request.auth.uid ||
                      isAdmin());

      allow update: if request.auth != null &&
                       (resource.data.providerId == request.auth.uid ||
                        resource.data.customerId == request.auth.uid);

      allow delete: if false;
    }

    // ---------------- chats ----------------
    match /chats/{chatId} {
      allow read: if request.auth != null &&
                  (isChatParticipant(resource.data) || isRequestParticipant(chatId));

      allow create: if request.auth != null &&
                    isNonEmptyString(request.resource.data.customerId) &&
                    isNonEmptyString(request.resource.data.providerId) &&
                    isRequestParticipant(chatId) &&
                    request.resource.data.customerId == get(/databases/$(database)/documents/serviceRequests/$(chatId)).data.customerId &&
                    request.resource.data.providerId == get(/databases/$(database)/documents/serviceRequests/$(chatId)).data.providerId;

      allow update: if request.auth != null &&
                    (isChatParticipant(resource.data) || isRequestParticipant(chatId)) &&
                    request.resource.data.customerId == resource.data.customerId &&
                    request.resource.data.providerId == resource.data.providerId;

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if request.auth != null && isRequestParticipant(chatId);

        allow create: if request.auth != null &&
                      isRequestParticipant(chatId) &&
                      request.resource.data.senderId == request.auth.uid &&
                      (isNonEmptyString(request.resource.data.text) ||
                       isNonEmptyString(request.resource.data.imageUrl));

        allow update: if request.auth != null &&
                      request.auth.uid == resource.data.senderId &&
                      request.resource.data.diff(resource.data).changedKeys().hasOnly(['isDeleted', 'deletedAt']) &&
                      request.resource.data.isDeleted == true &&
                      request.resource.data.deletedAt is timestamp;

        allow delete: if false;
      }
    }

    // ---------------- service_requests (chatbot logging) ----------------
    match /service_requests/{docId} {
      // Logging only; no sensitive data, can allow anonymous or logged-in writes
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ---------------- reviews (existing) ----------------
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
                    request.resource.data.customerId == request.auth.uid;
      allow update, delete: if request.auth != null &&
                            resource.data.customerId == request.auth.uid;
    }

    // ---------------- serviceReviews ----------------
    match /serviceReviews/{reviewId} {
      // Allow signed-in users to view service ratings/reviews in customer screens.
      allow read: if isSignedIn();

      // Customer can create review.
      allow create: if isSignedIn() &&
                    request.resource.data.customerId == request.auth.uid &&
                    serviceReviewBasicValid();

      // Customer can update their own review.
      allow update: if isSignedIn() &&
                    resource.data.customerId == request.auth.uid &&
                    request.resource.data.customerId == resource.data.customerId &&
                    request.resource.data.requestId == resource.data.requestId &&
                    serviceReviewBasicValid();

      // Customer can delete their own review
      allow delete: if isSignedIn() &&
                    resource.data.customerId == request.auth.uid;
    }

    // ---------------- shopItemReviews (shop rating/review after delivery) ----------------
    match /shopItemReviews/{reviewId} {
      // Keep read authenticated-only to match existing review privacy.
      allow read: if isSignedIn();

      // Customer can add review only for their delivered purchased item.
      allow create: if isSignedIn() &&
                    request.resource.data.customerId == request.auth.uid &&
                    shopItemReviewValid(request.resource.data) &&
                    hasDeliveredShopOrder(
                      request.resource.data.orderId,
                      request.resource.data.itemId
                    );

      // Customer can edit their own review; orderId/itemId/customerId must stay same.
      allow update: if isSignedIn() &&
                    resource.data.customerId == request.auth.uid &&
                    request.resource.data.customerId == resource.data.customerId &&
                    request.resource.data.orderId == resource.data.orderId &&
                    request.resource.data.itemId == resource.data.itemId &&
                    shopItemReviewValid(request.resource.data) &&
                    hasDeliveredShopOrder(resource.data.orderId, resource.data.itemId);

      allow delete: if isSignedIn() &&
                    (resource.data.customerId == request.auth.uid || isAdmin());
    }

    // ---------------- notifications ----------------
    match /notifications/{notificationId} {
      allow read: if request.auth != null &&
                   resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
                     resource.data.userId == request.auth.uid;
      allow create: if request.auth != null &&
                    (
                      request.resource.data.createdBy == request.auth.uid ||
                      request.resource.data.userId == request.auth.uid
                    );
      allow delete: if request.auth != null &&
                     resource.data.userId == request.auth.uid;
    }

    // Explicit default deny (does not override more specific matches)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
